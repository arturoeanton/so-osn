# Build artifacts
osnos/build/
# Note: don't use a wildcard like `osnos/**/build/` — netsurf vendor
# dirs contain `build/` subdirs with code-gen scripts + data (Entities,
# Aliases, *.pl) that ARE part of the source tree and must be present
# on a fresh clone. Only the truly-generated build dirs go below.

# Generated images
*.iso
*.img
*.hdd

# Editor / OS cruft
.DS_Store
.vscode/
.idea/
compile_commands.json
.cache/

# Limine bootloader is installed on the host; never check it back in.
limine-binary/
edk2-ovmf/

# QEMU serial dump (regenerated on every graphical-mode run).
osnos/serial.log

# Vendor build outputs — generated by build_and_run.sh, never committed.
osnos/vendor/musl/build-osnos/obj/
osnos/vendor/musl/build-osnos/lib/
osnos/vendor/musl/build-osnos/config.mak
osnos/vendor/tinycc/config.h
osnos/vendor/tinycc/config.mak

# Auto-vendored on Linux when the distro doesn't package limine.
# It's a clone of the upstream binary branch, not source we maintain.
osnos/vendor/limine/
